# ==== БД ====
DATABASE_URL=postgresql://appuser:changeme@postgres:5432/shopdb?schema=public

# ==== Сервер ====
PORT=3000
NODE_ENV=production
# Откуда фронт. Можно несколько через запятую. * для разработки.
CORS_ORIGIN=https://your-domain.com

# ==== JWT ====
# 32+ символа. Сгенерируй: openssl rand -hex 32
JWT_SECRET=replace_me_with_32plus_random_chars

# ==== Telegram ====
# От @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-xxx
# Telegram ID админов через запятую (полный доступ)
ADMIN_TG_IDS=8044243116
# Telegram ID модераторов через запятую (read-only аналитика)
MODERATOR_TG_IDS=
# URL твоего фронта, который откроется как WebApp
WEBAPP_URL=https://your-domain.com

# ==== Загрузки ====
# Папка для фото подтверждений (закладки)
UPLOAD_DIR=/data/uploads
# Публичный префикс, по которому фото отдаются (через nginx)
PUBLIC_UPLOAD_URL=https://your-domain.com/uploads
